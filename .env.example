# --- Database (required for run persistence + averages) ---
# Local dev: postgres on your machine. Production: a Neon/Supabase URL.
DATABASE_URL=postgres://localhost:5432/storage_race

# --- Tapedrive (local CLI, devnet) ---
# Path to the tapedrive binary + your funded devnet keypair.
TAPEDRIVE_BIN=/Users/azuolascompy/code/tapedrive-cli/bin/tapedrive
TAPEDRIVE_KEYPAIR=/Users/azuolascompy/.config/solana/id.json

# --- Walrus (public testnet, no keys needed) ---
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# --- Cloudflare R2 (the centralized lane — fill when ready) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=        # e.g. https://pub-xxxx.r2.dev

# --- IPFS pinning (Pinata, free tier — fill when ready) ---
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# --- Better Auth (fill when wiring sign-in) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3005
